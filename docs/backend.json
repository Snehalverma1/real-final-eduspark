{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the EduSpark platform, encompassing both students and instructors, storing their general profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["student", "subject-teacher", "admin"] },
        "applicationStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "role", "createdAt", "updatedAt"]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents an educational course offered on the platform.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "description": "Exam category: SSC, Banking, etc." },
        "instructorId": { "type": "string" },
        "instructorName": { "type": "string" },
        "instructorAvatarUrl": { "type": "string", "format": "uri" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "difficultyLevel": { "type": "string" },
        "chapters": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["Published", "Draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "category", "instructorId", "status", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/courses/{courseId}",
        "definition": { "entityName": "Course", "schema": { "$ref": "#/backend/entities/Course" } }
      }
    ]
  }
}