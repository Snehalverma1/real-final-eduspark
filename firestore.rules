// Updated security rules for EduSpark - Live Teaching Support
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isApprovedTeacher() {
      let profile = getUserData();
      return isSignedIn() && profile.role != 'student' && profile.applicationStatus == 'approved';
    }

    function docExists() {
      return resource != null;
    }

    function isEnrolled(courseId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrollments/$(courseId));
    }

    function studentCanAccessCourse(courseData) {
      let userProfile = getUserData();
      return userProfile.role == 'student' && userProfile.class == courseData.targetClass;
    }

    function isStudentInCourseClass(courseId) {
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      let userProfile = getUserData();
      return userProfile.role == 'student' && userProfile.class == course.targetClass;
    }

    function isImmutableCourse() {
      return request.resource.data.id == resource.data.id &&
             request.resource.data.instructorId == resource.data.instructorId;
    }

    function isImmutableEnrollment() {
        return request.resource.data.id == resource.data.id &&
               request.resource.data.studentId == resource.data.studentId;
    }

    // --------------------------------------------------------------------
    // User Data
    // --------------------------------------------------------------------

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) && docExists()
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.applicationStatus == resource.data.applicationStatus
                    && request.resource.data.createdAt == resource.data.createdAt)
                 || (isAdmin() && docExists()
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isOwner(userId) && docExists();
    }

    // --------------------------------------------------------------------
    // Public Content
    // --------------------------------------------------------------------

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == categoryId;
      allow update: if isAdmin() && docExists() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && docExists();
    }

    match /courses/{courseId} {
      allow get: if isSignedIn() && (isOwner(resource.data.instructorId) || isAdmin() || isEnrolled(courseId) || studentCanAccessCourse(resource.data));
      allow list: if true;
      allow create: if isApprovedTeacher() && isOwner(request.resource.data.instructorId) && request.resource.data.id == courseId;
      allow update: if isSignedIn() && (isOwner(resource.data.instructorId) || isAdmin()) && docExists() && isImmutableCourse();
      allow delete: if isSignedIn() && (isOwner(resource.data.instructorId) || isAdmin()) && docExists();

      // Live Sessions Subcollection
      match /liveSessions/{sessionId} {
        allow read: if isSignedIn() && (isEnrolled(courseId) || isOwner(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId) || isAdmin());
        allow create, update, delete: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId) || isAdmin());
      }
    }

    // --------------------------------------------------------------------
    // User-Specific Private Data Tree
    // --------------------------------------------------------------------
    match /users/{userId} {
      match /draftCourses/{courseId} {
        allow get, delete, list: if isOwner(userId);
        allow create: if isApprovedTeacher() && isOwner(userId) 
                       && request.resource.data.instructorId == userId 
                       && request.resource.data.id == courseId
                       && request.resource.data.status == 'Draft';
        allow update: if isOwner(userId) && docExists() && isImmutableCourse();
      }

      match /enrollments/{courseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.studentId == userId && request.resource.data.id == courseId
                      && isStudentInCourseClass(courseId);
        allow update: if isOwner(userId) && docExists() && isImmutableEnrollment();
        allow delete: if isOwner(userId) && docExists();
      }
    }
  }
}